# PUERTO DEL SERVIDOR (Por defecto 3005, usado en desarrollo y para redirección HTTP en producción)
PORT=3005

# CADENA DE CONEXIÓN A LA BASE DE DATOS MONGODB
# (Ejemplo Local: mongodb://localhost:27017/SGS)
# (Ejemplo Nube Atlas: mongodb+srv://<usuario>:<password>@cluster.mongodb.net/SGS)
MONGODB_URI=TU_CADENA_DE_CONEXION_AQUI

# SECRETO PARA FIRMAR LOS TOKENS JWT
# (Genera una cadena aleatoria larga y guárdala en secreto)
JWT_SECRET=TU_CLAVE_SECRETA_SUPER_SEGURA_AQUI

# ENTORNO DE EJECUCIÓN (development | production)
NODE_ENV=development

# ORIGEN DEL FRONTEND PARA CORS (Ej: http://localhost:5173 o https://tu-dominio.com)
FRONTEND_URL=http://localhost:5173

# ============================================================
# CONFIGURACIÓN SSL/TLS (solo requerido en NODE_ENV=production)
# ============================================================

# Puerto HTTPS (por defecto 443)
HTTPS_PORT=443

# Rutas a los certificados SSL
# Desarrollo (auto-firmado): generados en ./ssl/key.pem y ./ssl/cert.pem
# Producción: rutas a los certificados emitidos por Let's Encrypt / Certbot
#   SSL_KEY_PATH=/etc/letsencrypt/live/tu-dominio.com/privkey.pem
#   SSL_CERT_PATH=/etc/letsencrypt/live/tu-dominio.com/fullchain.pem
SSL_KEY_PATH=./ssl/key.pem
SSL_CERT_PATH=./ssl/cert.pem
